# ============================================
# 必填（最小可跑配置）
# ============================================

# DeepSeek API（已注册，已充值，已生成 Key）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 可选：语音播放（v0.4 已切换到火山引擎豆包语音合成 2.0）
# 不配也能跑，文字对话完全可用，只是没有"听姐姐说话"功能
# 想开语音时：NEXT_PUBLIC_TTS_ENABLED=true + 填下面 3 个 VOLC_ 变量
# ============================================

# 总开关：true = 启用语音；false / 不填 = 禁用（默认）
NEXT_PUBLIC_TTS_ENABLED=false

# 火山引擎控制台：https://console.volcengine.com/speech/app
# 创建应用后勾选"豆包语音合成 2.0 字符版"，在 API Key 管理创建 Key
VOLC_APP_ID=your_app_id
VOLC_API_KEY=your_api_key
VOLC_RESOURCE_ID=seed-tts-2.0

# 三档音色（uranus 2.0）已在 lib/volcano-tts.ts 的 VOICE_CONFIG 中硬编码：
#   casual   → zh_female_qingchezizi_uranus_bigtts （清澈梓梓）
#   rational → zh_female_lingling_uranus_bigtts    （玲玲）
#   scathing → zh_female_gujie_uranus_bigtts       （顾姐）
# 如需更换，直接改代码，不通过环境变量控制

# 限制单次输出长度，控制 TTS 成本
TTS_MAX_CHARS=500
