# ============================================
# 必填（最小可跑配置）
# ============================================

# DeepSeek API（已注册，已充值，已生成 Key）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 可选：语音播放（十一维度 / ElevenLabs）
# 不配也能跑，文字对话完全可用，只是没有"听御姐版"
# 想开语音时：把 NEXT_PUBLIC_TTS_ENABLED 改成 true，并填下面 4 项
# ============================================

# 总开关：true = 启用语音；false / 不填 = 禁用（默认）
NEXT_PUBLIC_TTS_ENABLED=false

# 注册地址：https://elevenlabs.io
ELEVEN_API_KEY=xi-xxxxxxxxxxxxxxxx
ELEVEN_BASE_URL=https://api.elevenlabs.io
# 御姐 / 女王风格音色 ID（在 ElevenLabs Voice Library 选一个中文女声）
ELEVEN_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVEN_MODEL_ID=eleven_multilingual_v2

# 限制单次输出长度，控制 TTS 成本
TTS_MAX_CHARS=500
